# Optional Reddit OAuth credentials.
#
# Reddit metadata works WITHOUT any of this (the tool falls back to old.reddit, the Wayback
# Machine, RSS, and URL-derived titles). But Reddit blocks the public endpoints from many
# IPs/User-Agents, so for reliable results — especially for brand-new posts — register a free
# Reddit app and fill these in.
#
# How to get credentials (2 minutes, free):
#   1. Go to https://www.reddit.com/prefs/apps  (logged in)
#   2. "create another app..." → choose type "script" (or "web app")
#   3. name: anything (e.g. world-cup-archive); redirect uri: http://localhost:8080
#   4. After creating: CLIENT_ID is the string under the app name; SECRET is the "secret" field.
#
# Then copy this file to ".env" (which is git-ignored) and fill it in:
#   cp .env.example .env
#
# Usage limit on the free tier is ~100 requests/minute — far more than this tool needs.

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Optional. A descriptive User-Agent is recommended by Reddit. Default is "world-cup-archive/1.0".
# REDDIT_USER_AGENT=world-cup-archive/1.0 (by /u/yourusername)

# Optional. Only needed if your app type requires the "password" grant ("script" apps tied to
# your account). Leave blank to use app-only (client_credentials) read access, which is enough
# for reading public posts.
# REDDIT_USERNAME=
# REDDIT_PASSWORD=
